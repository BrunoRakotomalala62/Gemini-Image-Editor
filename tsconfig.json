{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@workspace/api-zod": ["./lib/api-zod/src/index.ts"],
      "@workspace/db": ["./lib/db/src/index.ts"],
      "@workspace/integrations-gemini-ai": ["./lib/integrations-gemini-ai/src/index.ts"]
    }
  },
  "include": ["src"]
}
